{
  "name": "@gregpriday/memory-mcp",
  "version": "0.1.0",
  "description": "A memory MCP server backed by Turso (libSQL) with OpenAI embeddings and LLM-powered query generation",
  "type": "module",
  "bin": {
    "memory-mcp": "./build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gregpriday/memory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gregpriday/memory-mcp/issues"
  },
  "homepage": "https://github.com/gregpriday/memory-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "turso",
    "libsql",
    "openai",
    "embeddings",
    "vector-search",
    "ai",
    "llm",
    "claude"
  ],
  "author": "Greg Priday <greg@siteorigin.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp -r src/prompts build/prompts",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:watch": "vitest --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration/",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "openai": "^4.80.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
